{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    // ── Language ─────────────────────────────────────────────
    "target":        "ES2020",
    "lib":           ["ES2020"],

    // ── Module — CommonJS so ts-node can execute directly ────
    "module":           "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop":  true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,

    // ── Strictness ───────────────────────────────────────────
    "strict":           true,
    "noImplicitAny":    true,
    "strictNullChecks": true,

    // ── Output ───────────────────────────────────────────────
    // Scripts are run directly with ts-node, not compiled to disk
    "noEmit":           false,
    "outDir":           "./.scripts-dist",

    // ── Paths — no Next.js @/* aliases needed in scripts ─────
    "baseUrl": "."
  },
  "include":  ["scripts/**/*.ts"],
  "exclude":  ["node_modules", "src", ".next"]
}
